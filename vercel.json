{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/uso", "destination": "/terms-of-use", "permanent": true },
    { "source": "/uso.html", "destination": "/terms-of-use", "permanent": true },
    { "source": "/privacidade", "destination": "/privacy-policy", "permanent": true },
    { "source": "/privacidade.html", "destination": "/privacy-policy", "permanent": true },
    { "source": "/termos", "destination": "/terms-of-service", "permanent": true },
    { "source": "/termos.html", "destination": "/terms-of-service", "permanent": true },
    { "source": "/termos-e-servicos", "destination": "/terms-of-service", "permanent": true },
    { "source": "/termos-e-servicos.html", "destination": "/terms-of-service", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/(.+\\.(?:css|js|svg|png|jpg|jpeg|gif|ico|woff|woff2))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
